# ── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/qr_api

# ── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Evolution API (pool dedicado) ────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8181
EVOLUTION_API_KEY=your-evolution-api-key

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4500
NODE_ENV=development

# ── URL publica da API (usada em doc_url e webhook callbacks) ────────────────
QR_API_PUBLIC_BASE_URL=https://api.qrapi.flipt.com.br/v1

# ── Anti-ban defaults ────────────────────────────────────────────────────────
QR_API_DEFAULT_DAILY_LIMIT=1000
QR_API_WARMUP_DAYS=5
QR_API_RATE_LIMIT_RPS=10

# ── HMAC de webhooks de saida ────────────────────────────────────────────────
QR_API_WEBHOOK_HMAC_SECRET_SALT=your-hmac-salt-min-32-chars-here

# ── Portal SaaS ──────────────────────────────────────────────────────────────
PORTAL_JWT_SECRET=troque-este-segredo-em-producao
PORTAL_PUBLIC_URL=http://localhost:4500/portal

# ── Console de operador (admin) ──────────────────────────────────────────────
# Emails que podem acessar /admin (separados por virgula). Em dev (NODE_ENV!=production)
# e lista vazia, qualquer usuario logado vira admin (conveniencia local).
ADMIN_EMAILS=joao@gorilashield.com.br

# ── Billing — provedor padrao (mercadopago | stripe) ────────────────────────
# Sem token do provedor escolhido, o checkout roda em modo MOCK (ativa assinatura
# na hora, sem cobranca) para testar o fluxo de ponta a ponta.
BILLING_PROVIDER=mercadopago

# Mercado Pago (PIX + cartao, foco BR) — deixe vazio para mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Stripe (cartao internacional) — deixe vazio para mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
